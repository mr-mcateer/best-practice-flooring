---
layout: layouts/base.njk
---

<section class="hero" style="min-height:50vh;">
  <div class="hero-bg" style="background-image:url('{{ heroImage }}');"></div>
  <div class="hero-content">
    <h1>{{ title }}</h1>
    <p>{{ subtitle }}</p>
    <a href="/contact/" class="btn btn-primary">Get a Free {{ serviceShort }} Estimate</a>
  </div>
</section>

<section class="section">
  <div class="section-inner" style="max-width:var(--content-width);margin:0 auto;">
    {{ content | safe }}
  </div>
</section>

<section class="section section-alt" aria-labelledby="process-heading-{{ serviceShort | lower }}">
  <div class="section-inner">
    <div class="section-header">
      <h2 id="process-heading-{{ serviceShort | lower }}">Our {{ serviceShort }} Installation Process</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <h3>Free Consultation</h3>
        <p>Ake visits your home to measure, inspect your subfloor, and discuss {{ serviceShort | lower }} options that fit your style and budget.</p>
      </div>
      <div class="process-step">
        <h3>Material Selection</h3>
        <p>We help you choose the perfect {{ serviceShort | lower }} flooring — considering durability, aesthetics, and your home's specific needs.</p>
      </div>
      <div class="process-step">
        <h3>Expert Installation</h3>
        <p>Ake personally installs your {{ serviceShort | lower }} flooring with precision and care, protecting your home throughout the process.</p>
      </div>
      <div class="process-step">
        <h3>Final Walkthrough</h3>
        <p>We inspect every detail together. We don't consider the job done until you're 100% satisfied.</p>
      </div>
    </div>
  </div>
</section>

{% if faqs %}
<section class="section" aria-labelledby="faq-heading-{{ serviceShort | lower }}">
  <div class="section-inner">
    <div class="section-header">
      <h2 id="faq-heading-{{ serviceShort | lower }}">{{ serviceShort }} FAQ</h2>
    </div>
    <div class="faq-list">
      {% for faq in faqs %}
      <details class="faq-item">
        <summary>{{ faq.q }}</summary>
        <div class="faq-answer"><p>{{ faq.a }}</p></div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section class="cta-section">
  <h2>Ready for New {{ serviceShort }} Floors?</h2>
  <p>Get a free, no-obligation estimate for your {{ serviceShort | lower }} flooring project.</p>
  <div class="cta-buttons">
    <a href="/contact/" class="btn btn-primary" style="background:#fff;color:var(--brand-primary);">Get Your Free Estimate</a>
    <a href="tel:+1{{ site.team.ake.phone }}" class="btn btn-secondary">Call {{ site.team.ake.phoneDisplay }}</a>
  </div>
</section>

{% block extra_structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "{{ title }}",
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "{{ site.name }}",
    "telephone": "+1{{ site.team.ake.phone }}"
  },
  "areaServed": [
    {"@type": "City", "name": "Independence"},
    {"@type": "City", "name": "Corvallis"},
    {"@type": "City", "name": "Salem"},
    {"@type": "City", "name": "Albany"},
    {"@type": "AdministrativeArea", "name": "Polk County, Oregon"},
    {"@type": "AdministrativeArea", "name": "Benton County, Oregon"}
  ],
  "description": "{{ description }}"
}
</script>
{% if faqs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {"@type":"Question","name":"{{ faq.q }}","acceptedAnswer":{"@type":"Answer","text":"{{ faq.a }}"}}{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
{% endblock %}
