---
layout: layouts/base.njk
---

<section class="hero" style="min-height:50vh;">
  <div class="hero-bg" style="background-image:url('{{ heroImage }}');" role="img" aria-label="{{ serviceShort }} flooring installation by Best Practice Flooring"></div>
  <div class="hero-content">
    <h1>{{ title }}</h1>
    <p>{{ subtitle }}</p>
    <a href="/contact/" class="btn btn-primary">Get a Free {{ serviceShort }} Estimate</a>
  </div>
</section>

<div class="trust-bar" style="background:var(--bg-secondary);padding:var(--space-md) 0;border-bottom:1px solid var(--border-color);">
  <div class="section-inner" style="display:flex;justify-content:center;flex-wrap:wrap;gap:var(--space-md) var(--space-xl);font-size:var(--text-sm);color:var(--text-secondary);font-weight:500;">
    <span style="display:flex;align-items:center;gap:var(--space-xs);">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Licensed &amp; Insured
    </span>
    <span style="display:flex;align-items:center;gap:var(--space-xs);">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Owner-Installed by Ake
    </span>
    <span style="display:flex;align-items:center;gap:var(--space-xs);">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      Free Estimates
    </span>
    <span style="display:flex;align-items:center;gap:var(--space-xs);">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-primary)" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      5-Star Rated
    </span>
  </div>
</div>

<section class="section">
  <div class="section-inner" style="max-width:var(--content-width);margin:0 auto;">
    {{ content | safe }}
  </div>
</section>

<section class="section section-alt" aria-labelledby="process-heading-{{ serviceShort | lower }}">
  <div class="section-inner">
    <div class="section-header">
      <h2 id="process-heading-{{ serviceShort | lower }}">Our {{ serviceShort }} Installation Process</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <h3>Free Consultation</h3>
        <p>Ake visits your home to measure, inspect your subfloor, and discuss {{ serviceShort | lower }} options that fit your style and budget.</p>
      </div>
      <div class="process-step">
        <h3>Material Selection</h3>
        <p>We help you choose the perfect {{ serviceShort | lower }} flooring — considering durability, aesthetics, and your home's specific needs.</p>
      </div>
      <div class="process-step">
        <h3>Expert Installation</h3>
        <p>Ake personally installs your {{ serviceShort | lower }} flooring with precision and care, protecting your home throughout the process.</p>
      </div>
      <div class="process-step">
        <h3>Final Walkthrough</h3>
        <p>We inspect every detail together. We don't consider the job done until you're 100% satisfied.</p>
      </div>
    </div>
  </div>
</section>

{% if faqs %}
<section class="section" aria-labelledby="faq-heading-{{ serviceShort | lower }}">
  <div class="section-inner">
    <div class="section-header">
      <h2 id="faq-heading-{{ serviceShort | lower }}">{{ serviceShort }} FAQ</h2>
    </div>
    <div class="faq-list">
      {% for faq in faqs %}
      <details class="faq-item">
        <summary>{{ faq.q }}</summary>
        <div class="faq-answer"><p>{{ faq.a }}</p></div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section class="section" aria-labelledby="related-services">
  <div class="section-inner">
    <div class="section-header">
      <h2 id="related-services">Other Flooring We Install</h2>
    </div>
    <div class="services-grid">
      {% for svc in site.services %}
      {% if svc.shortName != serviceShort %}
      <div class="service-card">
        <img src="/assets/images/services/{{ svc.icon }}.jpg" alt="{{ svc.name }} installation" class="service-card-img" width="600" height="400" loading="lazy">
        <div class="service-card-body">
          <h3>{{ svc.name }}</h3>
          <p>{{ svc.description }}</p>
          <a href="/services/{{ svc.slug }}/" class="service-card-link">
            Learn more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta-section">
  <h2>Ready for New {{ serviceShort }} Floors?</h2>
  <p>Get a free, no-obligation estimate for your {{ serviceShort | lower }} flooring project.</p>
  <div class="cta-buttons">
    <a href="/contact/" class="btn btn-primary" style="background:#fff;color:var(--brand-primary);">Get Your Free Estimate</a>
    <a href="tel:+1{{ site.team.ake.phone }}" class="btn btn-secondary">Call {{ site.team.ake.phoneDisplay }}</a>
  </div>
  <p style="font-size:var(--text-sm);opacity:0.85;margin-top:var(--space-md);">We typically book 2–3 weeks out. Call today to get on the schedule.</p>
</section>

{% block extra_structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "{{ title }}",
  "provider": {"@id": "{{ site.url }}/#business"},
  "areaServed": [
    {% for area in site.serviceAreas %}
    {"@type": "City", "name": "{{ area }}"}{% if not loop.last %},{% endif %}
    {% endfor %},
    {"@type": "AdministrativeArea", "name": "Polk County, Oregon"},
    {"@type": "AdministrativeArea", "name": "Benton County, Oregon"}
  ],
  "description": "{{ description }}"
}
</script>
{% if faqs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {"@type":"Question","name":"{{ faq.q }}","acceptedAnswer":{"@type":"Answer","text":"{{ faq.a }}"}}{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
{% endblock %}
