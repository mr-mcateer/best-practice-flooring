<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ titleTag or title }} | Best Practice Flooring</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="keywords" content="{{ keywords or 'flooring installation, hardwood floors, LVP flooring, tile installation, laminate flooring, Corvallis flooring, Independence Oregon, flooring contractor, floor installer near me, Mid-Willamette Valley' }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ titleTag or title }} | Best Practice Flooring">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:image" content="{{ site.url }}{{ ogImage or '/assets/images/hero/hero-main.jpg' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ titleTag or title }} | Best Practice Flooring">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or '/assets/images/hero/hero-main.jpg' }}">

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- Font preconnect + load -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bitter:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Preload critical hero image (only on pages with hero) -->
  {% if heroImage %}
  <link rel="preload" as="image" href="{{ heroImage }}" fetchpriority="high">
  {% elif page.url == "/" %}
  <link rel="preload" as="image" href="/assets/images/hero/hero-tile.jpg" fetchpriority="high">
  {% endif %}

  <!-- CSS -->
  <link rel="stylesheet" href="/assets/css/output.css">

  <!-- Fallback: show content if JS is disabled -->
  <noscript><style>.fade-in-section { opacity: 1 !important; transform: none !important; }</style></noscript>

  <!-- Prevent FOUC: inline theme detection -->
  <script>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || t === 'light') {
        document.documentElement.setAttribute('data-theme', t);
      }
    })();
  </script>

  <!-- Structured Data: @graph with multiple types -->
  {% block structured_data %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "HomeAndConstructionBusiness",
        "@id": "{{ site.url }}/#business",
        "name": "{{ site.name }}",
        "description": "{{ site.description }}",
        "telephone": "+1{{ site.team.ake.phone }}",
        "email": "{{ site.email }}",
        "contactPoint": [
          {"@type": "ContactPoint", "telephone": "+1{{ site.team.sarah.phone }}", "contactType": "customer service", "name": "Sarah — Scheduling"}
        ],
        "sameAs": ["https://www.google.com/maps/place/Best+Practice+Flooring+LLC"],
        "url": "{{ site.url }}",
        "logo": "{{ site.url }}/favicon.svg",
        "image": "{{ site.url }}/assets/images/hero/hero-main.jpg",
        "priceRange": "$$",
        "currenciesAccepted": "USD",
        "paymentAccepted": "Cash, Check, Credit Card",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Independence",
          "addressRegion": "OR",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 44.8512,
          "longitude": -123.1868
        },
        "areaServed": [
          {"@type": "City", "name": "Independence", "sameAs": "https://en.wikipedia.org/wiki/Independence,_Oregon"},
          {"@type": "City", "name": "Corvallis", "sameAs": "https://en.wikipedia.org/wiki/Corvallis,_Oregon"},
          {"@type": "City", "name": "Salem", "sameAs": "https://en.wikipedia.org/wiki/Salem,_Oregon"},
          {"@type": "City", "name": "Albany", "sameAs": "https://en.wikipedia.org/wiki/Albany,_Oregon"},
          {"@type": "City", "name": "Monmouth"},
          {"@type": "City", "name": "Dallas"},
          {"@type": "City", "name": "Philomath"},
          {"@type": "AdministrativeArea", "name": "Polk County, Oregon"},
          {"@type": "AdministrativeArea", "name": "Benton County, Oregon"}
        ],
        "founder": [
          {"@type": "Person", "name": "{{ site.team.ake.name }}", "jobTitle": "{{ site.team.ake.title }}"},
          {"@type": "Person", "name": "{{ site.team.sarah.name }}", "jobTitle": "{{ site.team.sarah.title }}"}
        ],
        "openingHoursSpecification": [
          {"@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00"},
          {"@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "14:00"}
        ],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
          "reviewCount": "3",
          "bestRating": "5",
          "worstRating": "1"
        },
        "review": [
          {"@type": "Review", "author": {"@type": "Person", "name": "Jennifer L."}, "reviewRating": {"@type": "Rating", "ratingValue": "5"}, "reviewBody": "Sarah made scheduling so easy, and Ake's tile work in our bathroom is beautiful."},
          {"@type": "Review", "author": {"@type": "Person", "name": "Michael R."}, "reviewRating": {"@type": "Rating", "ratingValue": "5"}, "reviewBody": "Ake did an incredible job on our hardwood floors. Professional, on time, and quality exceeded expectations."},
          {"@type": "Review", "author": {"@type": "Person", "name": "David & Karen T."}, "reviewRating": {"@type": "Rating", "ratingValue": "5"}, "reviewBody": "We had LVP installed throughout our entire first floor. The work was meticulous and done faster than expected."}
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Flooring Services",
          "itemListElement": [
            {% for svc in site.services %}
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "{{ svc.name }} Installation"}}{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        }
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "{{ site.name }}",
        "publisher": {"@id": "{{ site.url }}/#business"}
      },
      {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}#webpage",
        "url": "{{ site.url }}{{ page.url }}",
        "name": "{{ title }}",
        "isPartOf": {"@id": "{{ site.url }}/#website"},
        "about": {"@id": "{{ site.url }}/#business"}
      }
    ]
  }
  </script>
  {% endblock %}

  {% block extra_structured_data %}{% endblock %}
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  {% include "components/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}

  <!-- Mobile sticky CTA -->
  <a href="tel:+1{{ site.team.ake.phone }}" class="mobile-cta" aria-label="Call {{ site.team.ake.name }} at {{ site.team.ake.phoneDisplay }}">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    Call Now: {{ site.team.ake.phoneDisplay }}
  </a>

  <!-- SVG noise texture overlay for depth -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <!-- Theme toggle + mobile nav + scroll navbar script -->
  <script>
    // Theme toggle
    (function() {
      function toggleTheme() {
        var html = document.documentElement;
        var current = html.getAttribute('data-theme');
        var isDark = current === 'dark' ||
          (!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
        var next = isDark ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        document.querySelectorAll('[data-theme-toggle]').forEach(function(btn) {
          btn.setAttribute('aria-checked', next === 'dark' ? 'true' : 'false');
        });
        var msg = document.getElementById('theme-announce');
        if (msg) msg.textContent = next.charAt(0).toUpperCase() + next.slice(1) + ' mode enabled';
      }
      document.querySelectorAll('[data-theme-toggle]').forEach(function(btn) {
        btn.addEventListener('click', toggleTheme);
      });
    })();

    // Services dropdown toggle
    (function() {
      var trigger = document.querySelector('.nav-dropdown-trigger');
      var dropdown = document.querySelector('.nav-dropdown');
      if (!trigger || !dropdown) return;
      function closeDropdown() {
        dropdown.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
      trigger.addEventListener('click', function() {
        var open = dropdown.classList.toggle('is-open');
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function(e) {
        if (!dropdown.contains(e.target)) closeDropdown();
      });
      dropdown.addEventListener('focusout', function(e) {
        setTimeout(function() {
          if (!dropdown.contains(document.activeElement)) closeDropdown();
        }, 0);
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && dropdown.classList.contains('is-open')) {
          closeDropdown();
          trigger.focus();
        }
      });
    })();

    // Mobile nav toggle
    (function() {
      var btn = document.getElementById('mobile-nav-toggle');
      var nav = document.getElementById('mobile-nav');
      if (!btn || !nav) return;
      var hamburger = btn.querySelector('.hamburger-icon');
      var closeIcon = btn.querySelector('.close-icon');
      function toggleIcons(open) {
        if (hamburger) hamburger.style.display = open ? 'none' : '';
        if (closeIcon) closeIcon.style.display = open ? '' : 'none';
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      }
      btn.addEventListener('click', function() {
        var open = nav.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggleIcons(open);
        if (open) {
          nav.querySelector('a').focus();
        }
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && nav.classList.contains('is-open')) {
          nav.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
          toggleIcons(false);
          btn.focus();
        }
      });
      // Close mobile nav when any link inside it is clicked
      nav.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          nav.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
          toggleIcons(false);
        });
      });
      // Focus trap for mobile nav
      nav.addEventListener('keydown', function(e) {
        if (e.key !== 'Tab' || !nav.classList.contains('is-open')) return;
        var focusable = [btn].concat(Array.from(nav.querySelectorAll('a, button')));
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    })();

    // Scroll-triggered navbar: glass blur + shadow on scroll
    (function() {
      var header = document.querySelector('.site-header');
      if (!header) return;
      var scrolled = false;
      function onScroll() {
        var y = window.scrollY || window.pageYOffset;
        if (y > 50 && !scrolled) {
          scrolled = true;
          header.classList.add('is-scrolled');
        } else if (y <= 50 && scrolled) {
          scrolled = false;
          header.classList.remove('is-scrolled');
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();

    // Intersection Observer: fade-in sections on scroll
    (function() {
      try {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.section, .cta-section, .page-header').forEach(function(el) {
          el.classList.add('fade-in-section');
          observer.observe(el);
        });
      } catch(e) { /* Gracefully degrade: content stays visible */ }
    })();
  </script>
  <div id="theme-announce" class="visually-hidden" aria-live="polite" role="status"></div>
</body>
</html>
